---
type Props = {
  name: "github" | "linkedin" | "instagram";
};

const { name } = Astro.props;

const labels = {
  github: "GitHub",
  linkedin: "LinkedIn",
  instagram: "Instagram"
};
---

<span class="sr-only">{labels[name]}</span>
